# Sao chép file này thành .env và điền giá trị thật trước khi deploy production.
# Ở môi trường demo, có thể để trống ANTHROPIC_API_KEY — hệ thống tự dùng fallback rule-based.

SECRET_KEY=doi-thanh-chuoi-ngau-nhien-that-dai-truoc-khi-deploy-that
DATABASE_PATH=./data/dtu_platform.db

# Để trống nếu chưa có key thật — chatbot và AI soạn nháp sẽ tự chuyển sang chế độ rule-based
ANTHROPIC_API_KEY=

# Để trống nếu dùng Fanpage test — endpoint duyet-va-dang sẽ mô phỏng thay vì gọi Facebook thật
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

JWT_EXP_MINUTES=480
SHARE_TARGET_PER_PERIOD=5
CORS_ALLOWED_ORIGINS=*
PORT=8000
